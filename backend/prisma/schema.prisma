generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  resetOtps     PasswordResetOtp[]
  notes         Note[]
  tags          Tag[]
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  // Set only when this token was revoked as part of rotation (i.e. replaced by a
  // newer token via /refresh). Null if revoked via logout, or never revoked.
  // Distinguishes "replay of a rotated token" (compromise signal) from "replay of
  // a logout-revoked token" (already dead, no further action needed) in reuse
  // detection — without this, a retried logout call would look identical to a
  // stolen-token replay and incorrectly mass-revoke every other session.
  rotatedToId String?

  @@index([userId])
}

model PasswordResetOtp {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Note {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  searchVector Unsupported("tsvector")?

  versions  NoteVersion[]
  tags      Tag[]         @relation("NoteTags")
  shareLink ShareLink?

  @@index([userId, deletedAt])
}

model NoteVersion {
  id        String   @id @default(uuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  title     String
  content   String
  createdAt DateTime @default(now())

  @@index([noteId, createdAt])
}

model Tag {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime @default(now())

  notes     Note[]   @relation("NoteTags")

  @@index([userId])
}

model ShareLink {
  id        String    @id @default(uuid())
  noteId    String    @unique
  note      Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  token     String    @unique
  viewCount Int       @default(0)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}
