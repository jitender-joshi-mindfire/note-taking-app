{
  "name": "note-taking-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x",
    "pnpm": "11.x"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "test": "pnpm -r run test",
    "dev:frontend": "pnpm --filter @note-taking-app/frontend dev",
    "dev:backend": "pnpm --filter @note-taking-app/backend dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "eslint": "10.6.0",
    "husky": "9.1.7",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  }
}
